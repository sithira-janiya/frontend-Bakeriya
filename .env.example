# Copy to ".env" to point the frontend at your backend.
#
# In development you can leave these blank: vite proxies /api and /ws to the
# backend on http://localhost:4000 (see vite.config.js). Set them for
# production / when the backend runs elsewhere.

# REST API base, e.g. https://api.bakerya.com  (no trailing slash). Blank = use vite proxy.
VITE_API_URL=http://localhost:4000

# WebSocket URL, e.g. wss://api.bakerya.com/ws. Blank = derive from page origin + /ws.
VITE_WS_URL=ws://localhost:4000/ws
